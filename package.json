{
  "name": "tomoshibi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm-run-all -p dev:public-site dev:admin-console dev:tomoshibi-mobile",
    "dev:public-site": "npm --prefix apps/public-site run dev -- --port 3000",
    "dev:admin-console": "npm --prefix apps/admin-console run dev -- --port 3001",
    "dev:tomoshibi-mobile": "EXPO_NO_METRO_WORKSPACE_ROOT=1 npm --prefix apps/tomoshibi-mobile run start:expo -- --web --port 8081",
    "dev:tomoshibi-master-mvp": "npm --prefix apps/tomoshibi-master-mvp run dev -- --port 8082",
    "emulators:tomoshibi-master-mvp": "npm --prefix apps/tomoshibi-master-mvp run emulators:start:persistent",
    "dev:tomoshibi-master-mvp:full": "npm-run-all -p emulators:tomoshibi-master-mvp dev:tomoshibi-master-mvp"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
