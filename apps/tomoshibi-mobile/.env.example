EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
EXPO_PUBLIC_MASTRA_BASE_URL=http://127.0.0.1:4111
EXPO_PUBLIC_SERIES_VNEXT_STRICT=true
EXPO_PUBLIC_SERIES_VNEXT_REQUEST_TIMEOUT_MS=180000
EXPO_PUBLIC_GOOGLE_OAUTH_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_OAUTH_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_OAUTH_ANDROID_CLIENT_ID=

# Mastra image generation (optional)
# Mobile app reads only EXPO_PUBLIC_MASTRA_BASE_URL.
# The rest are consumed by mastra/.env at runtime.
SERIES_IMAGE_DELIVERY=proxy
MASTRA_PUBLIC_BASE_URL=http://127.0.0.1:4111
SERIES_IMAGE_PROVIDER=gemini
SERIES_IMAGE_GEMINI_MODEL=gemini-3-pro-image-preview
SERIES_IMAGE_EVAL_MODEL=gemini-2.0-flash
SERIES_IMAGE_GEMINI_FALLBACK=on
SERIES_IMAGE_CACHE_TTL_SEC=21600
SERIES_IMAGE_CACHE_LIMIT=96
SERIES_IMAGE_HYBRID_ORDER=vertex,diffusers,gemini,pollinations
SERIES_IMAGE_VERTEX_ENDPOINT=
SERIES_IMAGE_VERTEX_TOKEN=
SERIES_IMAGE_DIFFUSERS_ENDPOINT=
SERIES_IMAGE_DIFFUSERS_TOKEN=
SERIES_IMAGE_PROVIDER_URL=https://image.pollinations.ai/prompt
SERIES_IMAGE_PROVIDER_MODEL=flux

# Optional: real-world grounding sources (series/episode separated).
# Series Step2: campus/地域全体の歴史・都市伝説・豆知識など「スポット非固定」情報を置くシート。
# If empty, Step2 works with prompt/design brief only.
SERIES_CONCEPT_GROUNDING_SERIES_SHEET_URL=

# Episode runtime: 具体スポット情報（スポット名/説明/位置/タグなど）を置くシート。
# If empty, episode runtime uses existing synthetic/fallback candidate logic.
EPISODE_SPOT_GROUNDING_SHEET_URL=

# Google Maps
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_API_KEY=   # Android ネイティブ用
EXPO_PUBLIC_GOOGLE_MAPS_WEB_API_KEY=       # Web ブラウザ用（Cursor 等でのテスト）

# Firebase App Distribution
# Android App ID example: 1:1234567890:android:abc123def456
FIREBASE_APP_ID_ANDROID=
# iOS App ID example: 1:1234567890:ios:abc123def456
FIREBASE_APP_ID_IOS=
FIREBASE_TESTERS=
FIREBASE_GROUPS=
FIREBASE_PROJECT_ID=
# CI only (local is "firebase login")
FIREBASE_TOKEN=
