{
  "expo": {
    "name": "TOMOSHIBI Mobile",
    "slug": "tomoshibi-mobile",
    "scheme": "com.tomoshibi.mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F8F7F6"
    },
    "ios": {
      "bundleIdentifier": "com.tomoshibi.mobile",
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "ゲームプレイ中に現在地を利用してスポット到着を判定します。"
      }
    },
    "android": {
      "package": "com.tomoshibi.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F8F7F6"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ゲームプレイ中に現在地を利用してスポット到着を判定します。"
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "d2d9d251-a6ed-4a8b-bb54-27d70c8449bb"
      }
    }
  }
}
