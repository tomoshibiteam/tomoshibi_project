    "hono": "^4.5.0",
    "rembg-node": "^2.0.2",
    "sharp": "^0.33.5",
    "tsx": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.6.3"
  }
