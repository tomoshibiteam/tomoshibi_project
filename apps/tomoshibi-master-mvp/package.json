{
  "name": "iwami_proof_of_concept",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:prod": "NEXT_PUBLIC_USE_FIREBASE_EMULATORS=false next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "deploy:prod": "firebase deploy --project tomoshibi-950e2 --only firestore:rules,functions",
    "seed:spots:prod": "npm --prefix functions run seed:spots:prod",
    "emulators:start:persistent": "bash ./scripts/start-emulators-persistent.sh",
    "emulators:start": "JAVA_HOME=/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home PATH=/opt/homebrew/opt/openjdk@21/bin:$PATH firebase emulators:start --project tomoshibi-950e2 --only firestore,functions,storage --config firebase.json --import=.firebase/emulator-data --export-on-exit=.firebase/emulator-data",
    "emulators:export": "JAVA_HOME=/opt/homebrew/opt/openjdk@21/libexec/openjdk.jdk/Contents/Home PATH=/opt/homebrew/opt/openjdk@21/bin:$PATH firebase emulators:export .firebase/emulator-data --project tomoshibi-950e2 --config firebase.json --force",
    "seed:tomoshibi-ai:emulator": "npm --prefix functions run seed:tomoshibi-ai:emulator",
    "seed:spots:emulator": "npm --prefix functions run seed:spots:emulator",
    "seed:spots:iwami-core:emulator": "npm --prefix functions run seed:spots:iwami-core:emulator",
    "seed:transit:emulator": "npm --prefix functions run seed:transit:emulator",
    "backfill:spots:operational:emulator": "npm --prefix functions run backfill:spots:operational:emulator",
    "report:spots:operational-gaps:emulator": "npm --prefix functions run report:spots:operational-gaps:emulator",
    "import:spots:openinfo-csv:emulator": "npm --prefix functions run import:spots:openinfo-csv:emulator",
    "import:spots:missing-fields-verified-csv:emulator": "npm --prefix functions run import:spots:missing-fields-verified-csv:emulator",
    "import:transit:gtfs:emulator": "npm --prefix functions run import:transit:gtfs:emulator"
  },
  "dependencies": {
    "firebase": "^12.12.1",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "firebase-tools": "^15.15.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
