{
  "expo": {
    "name": "TOMOSHIBI",
    "slug": "kyudai-dictionary-mvp-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "AR表示のためカメラを利用します。"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "現在地を使って周辺ルートを表示するため、位置情報を利用します。"
        }
      ]
    ]
  }
}
